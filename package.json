{
  "name": "pal",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.evals.json --noEmit",
    "build:client": "bun run scripts/build-client.ts",
    "dev": "bun x wrangler dev",
    "deploy": "bun run build:client && bun x wrangler deploy",
    "cf-typegen": "bun x wrangler types",
    "evals": "vitest run --config vitest.evals.config.ts --reporter=vitest-evals/reporter",
    "evals:watch": "vitest --config vitest.evals.config.ts --reporter=vitest-evals/reporter",
    "evals:verbose": "vitest run --config vitest.evals.config.ts --reporter=vitest-evals/reporter -- -vv"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@cloudflare/workers-types": "^4.20251108.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest-evals/harness-ai-sdk": "0.10.0",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.6",
    "vitest-evals": "0.10.0",
    "wrangler": "^4.50.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/react": "^3.0.186",
    "@cloudflare/ai-chat": "^0.7.0",
    "@cloudflare/shell": "^0.3.7",
    "@cloudflare/think": "^0.6.1",
    "@langfuse/otel": "^5",
    "@langfuse/tracing": "^5",
    "@opentelemetry/api": "^1.9",
    "@opentelemetry/core": "^2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218",
    "@opentelemetry/sdk-trace-base": "^2",
    "@opentelemetry/sdk-trace-node": "^2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "agents": "^0.12.4",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "nanoid": "^5.1.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  }
}
